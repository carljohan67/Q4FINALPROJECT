                <else>
                    <if expression="answer4=2">
                        <then>
                            <output expression="&quot;Please input your grades and only pick from 1.00, 1.25, 1.50, 1.75, 2.00, 2.25, 2.50, 2.75, 3.00, 4.00 and 5.00 unless its Values Education&quot;" newline="True"/>
                            <for variable="i" start="0" end="12" direction="inc" step="1">
                                <output expression="subjects[i] &amp; &quot;:&quot;" newline="True"/>
                                <assign variable="subject" expression="subjects[i]"/>
                                <if expression="subject=subjects[12]">
                                    <then>
                                        <output expression="&quot;Please input complete or incomplete&quot;" newline="True"/>
                                        <input variable="status"/>
                                        <while expression="status!=&quot;complete&quot; and status!=&quot;incomplete&quot;">
                                            <output expression="&quot;Please input only complete or incomplete&quot;" newline="True"/>
                                            <input variable="status"/>
                                        </while>
                                    </then>
                                    <else>
                                        <input variable="grades[i]"/>
                                        <while expression="grades[i] != 1.00 and&#13;&#10;        grades[i] != 1.25 and&#13;&#10;        grades[i] != 1.50 and&#13;&#10;        grades[i] != 1.75 and&#13;&#10;        grades[i] != 2.00 and&#13;&#10;        grades[i] != 2.25 and&#13;&#10;        grades[i] != 2.50 and&#13;&#10;        grades[i] != 2.75 and&#13;&#10;        grades[i] != 3.00 and&#13;&#10;        grades[i] != 4.00 and&#13;&#10;        grades[i] != 5.00">
                                            <output expression="&quot;Invalid grade please try again&quot;" newline="True"/>
                                            <output expression="subjects[i]&amp; &quot;:&quot;" newline="True"/>
                                            <input variable="grades[i]"/>
                                        </while>
                                        <assign variable="gradesformatted[i]" expression="ToFixed(grades[i],2)"/>
                                    </else>
                                </if>
                            </for>
                            <if expression="status=&quot;complete&quot;">
                                <then>
                                    <output expression="subjects[0] &amp; &quot;:&quot; &amp; gradesformatted[0] &amp; &quot; &quot; &amp;&#13;&#10;subjects[1] &amp; &quot;:&quot; &amp; gradesformatted[1] &amp; &quot; &quot; &amp;&#13;&#10;subjects[2] &amp; &quot;:&quot; &amp; gradesformatted[2] &amp; &quot; &quot; &amp;&#13;&#10;subjects[3] &amp; &quot;:&quot; &amp; gradesformatted[3] &amp; &quot; &quot; &amp;&#13;&#10;subjects[4] &amp; &quot;:&quot; &amp; gradesformatted[4] &amp; &quot; &quot; &amp;&#13;&#10;subjects[5] &amp; &quot;:&quot; &amp; gradesformatted[5] &amp; &quot; &quot; &amp;&#13;&#10;subjects[6] &amp; &quot;:&quot; &amp; gradesformatted[6] &amp; &quot; &quot; &amp;&#13;&#10;subjects[7] &amp; &quot;:&quot; &amp; gradesformatted[7] &amp; &quot; &quot; &amp;&#13;&#10;subjects[8] &amp; &quot;:&quot; &amp; gradesformatted[8] &amp; &quot; &quot; &amp;&#13;&#10;subjects[9] &amp; &quot;:&quot; &amp; gradesformatted[9] &amp; &quot; &quot; &amp;&#13;&#10;subjects[10] &amp; &quot;:&quot; &amp; gradesformatted[10] &amp; &quot; &quot; &amp;&#13;&#10;subjects[11] &amp; &quot;:&quot; &amp; gradesformatted[11] &amp; &quot; &quot; &amp;&#13;&#10;subjects[12] &amp; &quot;:&quot; &amp; status" newline="True"/>
                                    <assign variable="TotalGWA" expression="(grades[0]+grades[1]+grades[2]+grades[3]+grades[4]+grades[5]+grades[6]+grades[7]+grades[8]&#13;&#10;+grades[9]+grades[10]+(grades[11]*1.3))/12.3"/>
                                    <assign variable="totalgwarounded" expression="ToFixed(TotalGWA,2)"/>
                                    <if expression="TotalGWA&lt;=1.50">
                                        <then>
                                            <output expression="&quot;Final GWA:&quot; &amp; totalgwarounded &amp; &quot; &quot; &amp; &quot;Congrats you are apart of the Director's List!&quot;" newline="True"/>
                                        </then>
                                        <else>
                                            <output expression="&quot;Final GWA:&quot; &amp; totalgwarounded" newline="True"/>
                                        </else>
                                    </if>
                                    <output expression="&quot;Program is closing&quot;" newline="True"/>
                                </then>
                                <else>
                                    <output expression="subjects[0] &amp; &quot;:&quot; &amp; gradesformatted[0] &amp; &quot; &quot; &amp;&#13;&#10;subjects[1] &amp; &quot;:&quot; &amp; gradesformatted[1] &amp; &quot; &quot; &amp;&#13;&#10;subjects[2] &amp; &quot;:&quot; &amp; gradesformatted[2] &amp; &quot; &quot; &amp;&#13;&#10;subjects[3] &amp; &quot;:&quot; &amp; gradesformatted[3] &amp; &quot; &quot; &amp;&#13;&#10;subjects[4] &amp; &quot;:&quot; &amp; gradesformatted[4] &amp; &quot; &quot; &amp;&#13;&#10;subjects[5] &amp; &quot;:&quot; &amp; gradesformatted[5] &amp; &quot; &quot; &amp;&#13;&#10;subjects[6] &amp; &quot;:&quot; &amp; gradesformatted[6] &amp; &quot; &quot; &amp;&#13;&#10;subjects[7] &amp; &quot;:&quot; &amp; gradesformatted[7] &amp; &quot; &quot; &amp;&#13;&#10;subjects[8] &amp; &quot;:&quot; &amp; gradesformatted[8] &amp; &quot; &quot; &amp;&#13;&#10;subjects[9] &amp; &quot;:&quot; &amp; gradesformatted[9] &amp; &quot; &quot; &amp;&#13;&#10;subjects[10] &amp; &quot;:&quot; &amp; gradesformatted[10] &amp; &quot; &quot; &amp;&#13;&#10;subjects[11] &amp; &quot;:&quot; &amp; gradesformatted[11] &amp; &quot; &quot; &amp;&#13;&#10;subjects[12] &amp; &quot;:&quot; &amp; status" newline="True"/>
                                    <assign variable="TotalGWA" expression="(grades[0]+grades[1]+grades[2]+grades[3]+grades[4]+grades[5]+grades[6]+grades[7]+grades[8]&#13;&#10;+grades[9]+grades[10]+(grades[11]*1.3))/12.3"/>
                                    <assign variable="totalgwarounded" expression="ToFixed(TotalGWA,2)"/>
                                    <output expression="&quot;Final GWA:&quot; &amp; totalgwarounded&amp;&quot;(Probationary Status: Please complete your ValEd requirements)&quot;" newline="True"/>
                                    <output expression="&quot;Program is closing&quot;" newline="True"/>
                                </else>
                            </if>
                        </then>
                        <else>
                            <output expression="&quot;Program is closing&quot;" newline="True"/>
                        </else>
                    </if>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
